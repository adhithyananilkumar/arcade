# Committed on purpose (see mock/README.md): mock mode + auth bypass are on
# by default for anyone who checks out this branch. Never copy these two
# lines into .env.production*  — next.config.ts and CI both hard-fail if you
# do. Set either to false locally if you want real backend/auth on mockui.
NEXT_PUBLIC_USE_MOCKS=true
NEXT_PUBLIC_AUTH_BYPASS=true
